# Configurações do Banco de Dados Postgres
PG_HOST=seu_host_aqui
PG_PORT=5432
PG_USER=seu_usuario_aqui
PG_PASSWORD=sua_senha_aqui
PG_DB=oliveira_db
PG_SSL=true

# Configurações da API Gemini (Google Generative AI)
GEMINI_API_KEY=sua_chave_api_aqui

# Configurações do Servidor (opcional)
PORT=3000
NODE_ENV=development
